# mock: deterministic demo output with no network request
# auto: use OpenAI when a key is available, otherwise fall back safely
# live: prefer OpenAI, while still falling back if quota or validation fails
GENESIS_AI_MODE=mock

# Optional in mock mode. Required only when auto/live mode should call OpenAI.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6-sol
